---
const { recipe } = Astro.props;
const season = recipe.frontmatter.season;
---

<article class="recipe-card">
  <a href={recipe.url}>
    <img src={recipe.frontmatter.image} alt={recipe.frontmatter.title} loading="lazy" />
    <h3>{recipe.frontmatter.title}</h3>
  </a>
  <p class="recipe-meta">{season}</p>
</article>
