---
import '../styles.css';

const { title = 'Bridget Recipes' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a href="/" class="logo">Bridget</a>
        <nav class="nav" aria-label="Main">
          <a href="/">Home</a>
          <a href="/all-recipes">All Recipes</a>
          <div class="dropdown">
            <button aria-haspopup="true">Seasons</button>
            <div class="dropdown-menu" role="menu">
              <a href="/tags/spring">Spring</a>
              <a href="/tags/summer">Summer</a>
              <a href="/tags/fall">Fall</a>
              <a href="/tags/winter">Winter</a>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer class="site-footer"></footer>
  </body>
</html>
