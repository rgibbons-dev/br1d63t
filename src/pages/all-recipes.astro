---
import BaseLayout from '../layouts/BaseLayout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { allTags, recipes } from '../lib/recipes';
---

<BaseLayout title="All Recipes | Bridget Recipes">
  <section class="page-intro">
    <p class="eyebrow">All Recipes</p>
    <h1>The full collection</h1>
    <p>
      Every recipe in one place, ordered by date and cross-linked by season and ingredient.
    </p>
  </section>

  <ul class="tag-list page-tags" aria-label="Browse tags">
    {allTags.map((tag) => (
      <li>
        <a href={`/tags/${tag.toLowerCase().replace(/\s+/g, '-')}`}>{tag}</a>
      </li>
    ))}
  </ul>

  <div class="recipe-grid">
    {recipes.map((recipe) => (
      <RecipeCard recipe={recipe} />
    ))}
  </div>
</BaseLayout>
